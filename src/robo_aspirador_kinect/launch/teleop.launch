<!--
  Teleop por teclado (TurtleBot2).
  Publica em cmd_vel_mux/input/teleop — mesmo padrão do turtlebot_teleop oficial.
-->
<launch>
  <arg name="scale_linear" default="0.5"/>
  <arg name="scale_angular" default="1.5"/>

  <node pkg="turtlebot_teleop" type="turtlebot_teleop_key" name="turtlebot_teleop_keyboard" output="screen">
    <param name="scale_linear" value="$(arg scale_linear)"/>
    <param name="scale_angular" value="$(arg scale_angular)"/>
    <remap from="turtlebot_teleop_keyboard/cmd_vel" to="cmd_vel_mux/input/teleop"/>
  </node>
</launch>
